import React, { useState, useRef, useEffect } from 'react';
import { Upload, Image as ImageIcon, Code, Sparkles, AlertCircle, ArrowRight, Loader2, Copy, Check, Download } from 'lucide-react';

const apiKey = ""; // API key is provided by the execution environment

export default function App() {
  const [sourceImage, setSourceImage] = useState(null);
  const [promptElements, setPromptElements] = useState({
    style: "",
    ceiling: "",
    floor: "",
    walls: "",
    furniture: "",
    lighting: "",
    other: ""
  });
  const [generatedImage, setGeneratedImage] = useState(null);
  
  const [isExtracting, setIsExtracting] = useState(false);
  const [isGenerating, setIsGenerating] = useState(false);
  const [isDragging, setIsDragging] = useState(false);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(false);
  
  const fileInputRef = useRef(null);

  // Helper: Convert File to Base64
  const fileToBase64 = (file) => {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = () => resolve(reader.result);
      reader.onerror = (error) => reject(error);
    });
  };

  // Handle Image Upload
  const handleImageUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    
    try {
      const base64 = await fileToBase64(file);
      setSourceImage(base64);
      setError(null);
    } catch (err) {
      setError("Failed to read image file.");
    }
  };

  // Drag and Drop Handlers
  const handleDragOver = (e) => {
    e.preventDefault();
    e.stopPropagation();
  };

  const handleDragEnter = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragging(true);
  };

  const handleDragLeave = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragging(false);
  };

  const handleDrop = async (e) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragging(false);

    const file = e.dataTransfer.files[0];
    if (!file || !file.type.startsWith('image/')) {
      setError("Please drop a valid image file.");
      return;
    }

    try {
      const base64 = await fileToBase64(file);
      setSourceImage(base64);
      setError(null);
    } catch (err) {
      setError("Failed to read dropped image.");
    }
  };

  // Handle Paste Event
  useEffect(() => {
    const handlePaste = async (e) => {
      const items = e.clipboardData?.items;
      if (!items) return;

      for (let i = 0; i < items.length; i++) {
        if (items[i].type.indexOf('image') === 0) {
          e.preventDefault(); 
          const file = items[i].getAsFile();
          if (file) {
            try {
              const base64 = await fileToBase64(file);
              setSourceImage(base64);
              setError(null);
            } catch (err) {
              setError("Failed to read pasted image.");
            }
          }
          break; // Stop after processing the first image found
        }
      }
    };

    document.addEventListener('paste', handlePaste);
    return () => {
      document.removeEventListener('paste', handlePaste);
    };
  }, []);

  // API Call: Extract Image to JSON
  const extractToJson = async () => {
    if (!sourceImage) return;
    setIsExtracting(true);
    setError(null);
    
    try {
      const base64Data = sourceImage.split(',')[1];
      const mimeType = sourceImage.match(/[^:]\w+\/[\w-+\d.]+(?=;|,)/)[0] || "image/jpeg";

      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{
              parts: [
                { text: "Analyze this interior/architectural image. Extract detailed descriptions for the specific elements requested to help recreate the scene." },
                { inlineData: { mimeType, data: base64Data } }
              ]
            }],
            generationConfig: {
              responseMimeType: "application/json",
              responseSchema: {
                type: "OBJECT",
                properties: {
                  style: { type: "STRING", description: "Overall artistic style, mood, or photographic look" },
                  ceiling: { type: "STRING", description: "Description of the ceiling" },
                  floor: { type: "STRING", description: "Description of the floor" },
                  walls: { type: "STRING", description: "Description of the walls" },
                  furniture: { type: "STRING", description: "Description of main furniture" },
                  lighting: { type: "STRING", description: "Description of lighting setup" },
                  other: { type: "STRING", description: "Any other notable details" }
                }
              }
            }
          })
        }
      );

      if (!response.ok) throw new Error("Failed to extract details from image");
      
      const data = await response.json();
      const extractedText = data.candidates?.[0]?.content?.parts?.[0]?.text;
      
      if (extractedText) {
        const parsed = JSON.parse(extractedText);
        setPromptElements(prev => ({ ...prev, ...parsed }));
      }
    } catch (err) {
      setError(err.message || "Extraction failed.");
    } finally {
      setIsExtracting(false);
    }
  };

  // API Call: Generate New Image from JSON Prompt
  const generateNewImage = async () => {
    const hasContent = Object.values(promptElements).some(val => val && val.trim().length > 0);
    if (!hasContent) return;
    
    setIsGenerating(true);
    setError(null);
    setGeneratedImage(null);

    try {
      // Construct the prompt from the individual elements
      const promptParts = [];
      if (promptElements.style) promptParts.push(`Style/Mood: ${promptElements.style}`);
      if (promptElements.ceiling) promptParts.push(`Ceiling: ${promptElements.ceiling}`);
      if (promptElements.floor) promptParts.push(`Floor: ${promptElements.floor}`);
      if (promptElements.walls) promptParts.push(`Walls: ${promptElements.walls}`);
      if (promptElements.furniture) promptParts.push(`Furniture: ${promptElements.furniture}`);
      if (promptElements.lighting) promptParts.push(`Lighting: ${promptElements.lighting}`);
      if (promptElements.other) promptParts.push(`Additional details: ${promptElements.other}`);

      const promptText = promptParts.join(". ");

      if (!promptText) throw new Error("Prompt is empty.");

      let base64Img = null;

      if (sourceImage) {
        // Use Image-to-Image editing to preserve proportions and layout
        const base64Data = sourceImage.split(',')[1];
        const mimeType = sourceImage.match(/[^:]\w+\/[\w-+\d.]+(?=;|,)/)[0] || "image/jpeg";
        
        const editPrompt = `Re-render this exact scene. Strictly maintain the original layout, structure, proportions, and perspective. Update the materials and design based on these descriptions:\n\n${promptText}`;

        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{
                parts: [
                  { text: editPrompt },
                  { inlineData: { mimeType, data: base64Data } }
                ]
              }],
              generationConfig: {
                responseModalities: ['IMAGE']
              }
            })
          }
        );

        if (!response.ok) throw new Error("Failed to edit image.");
        const data = await response.json();
        base64Img = data.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
      } else {
        // Fallback to pure Text-to-Image if no source image exists
        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              instances: { prompt: promptText },
              parameters: { sampleCount: 1 }
            })
          }
        );

        if (!response.ok) throw new Error("Failed to generate image.");
        const data = await response.json();
        base64Img = data.predictions?.[0]?.bytesBase64Encoded;
      }

      if (base64Img) {
        setGeneratedImage(`data:image/png;base64,${base64Img}`);
      } else {
        throw new Error("No image data returned.");
      }
    } catch (err) {
      setError(err.message || "Image generation failed.");
    } finally {
      setIsGenerating(false);
    }
  };

  // Handle Copy JSON Payload
  const handleCopyJson = () => {
    const jsonString = JSON.stringify(promptElements, null, 2);
    const textArea = document.createElement("textarea");
    textArea.value = jsonString;
    // Move textarea out of viewport so it's invisible
    textArea.style.position = "absolute";
    textArea.style.left = "-999999px";
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    } catch (err) {
      console.error('Failed to copy', err);
    }
    textArea.remove();
  };

  return (
    <div className="min-h-screen bg-gray-950 text-gray-100 p-6 font-sans">
      <div className="max-w-6xl mx-auto space-y-6">
        
        <header className="flex items-center space-x-3 mb-8">
          <Sparkles className="w-8 h-8 text-blue-400" />
          <h1 className="text-2xl font-bold">Image ⇄ JSON Re-imager</h1>
        </header>

        {error && (
          <div className="bg-red-900/30 text-red-400 p-4 rounded-lg flex items-center space-x-2 border border-red-800/50">
            <AlertCircle className="w-5 h-5 flex-shrink-0" />
            <p className="text-sm font-medium">{error}</p>
          </div>
        )}

        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
          
          {/* Left Column: Extraction */}
          <div className="bg-gray-900 p-6 rounded-xl shadow-lg border border-gray-800 flex flex-col">
            <h2 className="text-lg font-semibold flex items-center space-x-2 mb-4 text-gray-200">
              <ImageIcon className="w-5 h-5 text-gray-400" />
              <span>1. Source Image</span>
            </h2>
            
            <div className="flex-grow flex flex-col space-y-4">
              <div 
                className={`border-2 border-dashed rounded-lg h-64 flex flex-col items-center justify-center relative overflow-hidden group cursor-pointer transition ${
                  isDragging 
                    ? 'border-blue-500 bg-gray-800/80 shadow-[0_0_15px_rgba(59,130,246,0.5)]' 
                    : 'border-gray-700 bg-gray-800/50 hover:bg-gray-800'
                }`}
                onClick={() => fileInputRef.current?.click()}
                onDragOver={handleDragOver}
                onDragEnter={handleDragEnter}
                onDragLeave={handleDragLeave}
                onDrop={handleDrop}
              >
                {sourceImage ? (
                  <img src={sourceImage} alt="Source" className="w-full h-full object-contain" />
                ) : (
                  <div className="text-center p-4">
                    <Upload className={`w-8 h-8 mx-auto mb-2 transition-colors ${isDragging ? 'text-blue-400' : 'text-gray-500'}`} />
                    <p className={`text-sm font-medium transition-colors ${isDragging ? 'text-blue-400' : 'text-gray-400'}`}>
                      {isDragging ? 'Drop image here' : 'Click, Paste, or Drop image'}
                    </p>
                  </div>
                )}
                <input 
                  type="file" 
                  ref={fileInputRef} 
                  onChange={handleImageUpload} 
                  accept="image/*" 
                  className="hidden" 
                />
              </div>

              <button
                onClick={extractToJson}
                disabled={!sourceImage || isExtracting}
                className="w-full py-3 px-4 bg-gray-800 hover:bg-gray-700 text-white border border-gray-700 rounded-lg font-medium transition disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center space-x-2"
              >
                {isExtracting ? (
                  <Loader2 className="w-5 h-5 animate-spin text-gray-400" />
                ) : (
                  <>
                    <span>Extract to JSON</span>
                    <ArrowRight className="w-4 h-4 text-gray-400" />
                  </>
                )}
              </button>

              <div className="flex flex-col space-y-2 mt-4 pt-4 border-t border-gray-800">
                <div className="flex justify-between items-center">
                  <label className="text-xs font-bold text-gray-400 uppercase tracking-wider">Live JSON Payload</label>
                  <button 
                    onClick={handleCopyJson}
                    className="text-xs flex items-center space-x-1 text-gray-400 hover:text-gray-200 transition bg-gray-800 hover:bg-gray-700 py-1 px-2 rounded"
                  >
                    {copied ? <Check className="w-3 h-3 text-green-400" /> : <Copy className="w-3 h-3" />}
                    <span>{copied ? 'Copied!' : 'Copy'}</span>
                  </button>
                </div>
                <div className="bg-gray-950 p-3 rounded-lg border border-gray-700 overflow-y-auto max-h-[160px] custom-scrollbar">
                  <pre className="text-xs text-green-400 font-mono whitespace-pre-wrap">
                    {JSON.stringify(promptElements, null, 2)}
                  </pre>
                </div>
              </div>
            </div>
          </div>

          {/* Right Column: Generation */}
          <div className="bg-gray-900 p-6 rounded-xl shadow-lg border border-gray-800 flex flex-col">
            <h2 className="text-lg font-semibold flex items-center space-x-2 mb-4 text-gray-200">
              <Code className="w-5 h-5 text-gray-400" />
              <span>2. Editable Elements</span>
            </h2>
            
            <div className="flex-grow flex flex-col space-y-4">
              <div className="flex flex-col space-y-4 bg-gray-800/50 p-4 rounded-lg border border-gray-700 overflow-y-auto max-h-[500px]">
                {Object.entries(promptElements).map(([key, value]) => (
                  <div key={key} className="flex flex-col space-y-1">
                    <label className="text-xs font-bold text-gray-400 uppercase tracking-wider">{key}</label>
                    <textarea
                      value={value || ''}
                      onChange={(e) => setPromptElements(prev => ({ ...prev, [key]: e.target.value }))}
                      className="w-full p-3 bg-gray-900 text-gray-200 text-sm rounded border border-gray-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none resize-none min-h-[100px] placeholder-gray-600"
                      placeholder={`Describe the ${key}...`}
                    />
                  </div>
                ))}
              </div>

              <button
                onClick={generateNewImage}
                disabled={!Object.values(promptElements).some(v => v?.trim()) || isGenerating}
                className="w-full py-3 px-4 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-medium transition disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center space-x-2 shadow-lg shadow-blue-900/20"
              >
                {isGenerating ? (
                  <Loader2 className="w-5 h-5 animate-spin" />
                ) : (
                  <>
                    <Sparkles className="w-4 h-4" />
                    <span>Generate New Image</span>
                  </>
                )}
              </button>

              <div className="border-2 border-gray-700 rounded-lg h-80 flex flex-col items-center justify-center bg-gray-800/50 relative overflow-hidden mt-2 group">
                {generatedImage ? (
                  <>
                    <img src={generatedImage} alt="Generated" className="w-full h-full object-contain" />
                    <a
                      href={generatedImage}
                      download="generated-room.png"
                      className="absolute bottom-4 right-4 bg-gray-900/80 hover:bg-gray-900 text-white py-2 px-3 rounded-lg backdrop-blur-sm border border-gray-700 transition opacity-0 group-hover:opacity-100 flex items-center space-x-2 shadow-lg"
                      title="Save Image"
                    >
                      <Download className="w-4 h-4" />
                      <span className="text-sm font-medium">Save</span>
                    </a>
                  </>
                ) : (
                  <div className="text-center p-4">
                    <ImageIcon className="w-8 h-8 text-gray-600 mx-auto mb-2" />
                    <p className="text-sm text-gray-500">Result will appear here</p>
                  </div>
                )}
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  );
}
